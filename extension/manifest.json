{
  "manifest_version": 3,
  "name": "Fanout Poster",
  "version": "0.4.1",
  "description": "Posts Fanout drafts to LinkedIn, X, Threads, Bluesky, Mastodon, Instagram, Reddit, and more — from your own browser session.",
  "permissions": [
    "storage",
    "alarms",
    "scripting",
    "activeTab",
    "clipboardWrite",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://www.linkedin.com/*",
    "https://www.threads.net/*",
    "https://www.instagram.com/*",
    "https://bsky.app/*",
    "https://mastodon.social/*",
    "https://hachyderm.io/*",
    "https://fosstodon.org/*",
    "https://indieweb.social/*",
    "https://mas.to/*",
    "https://www.reddit.com/*",
    "https://news.ycombinator.com/*",
    "https://www.producthunt.com/*",
    "https://medium.com/*",
    "https://dev.to/*",
    "https://web.telegram.org/*",
    "https://discord.com/*",
    "https://app.slack.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Fanout"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "src/content-x.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "src/content-linkedin.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.threads.net/*"
      ],
      "js": [
        "src/content-threads.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "src/content-instagram.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://bsky.app/*"
      ],
      "js": [
        "src/content-bluesky.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://mastodon.social/*",
        "https://hachyderm.io/*",
        "https://fosstodon.org/*",
        "https://indieweb.social/*",
        "https://mas.to/*"
      ],
      "js": [
        "src/content-mastodon.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
