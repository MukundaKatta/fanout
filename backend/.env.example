# LLM
GROQ_API_KEY=your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Database — Supabase Postgres connection string (Settings > Database > Connection string > URI)
# For local dev, you can also use a local Postgres or sqlite by changing this.
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/fanout

# Supabase auth — JWT secret from Settings > API > JWT Settings > JWT Secret
# Leave empty to disable auth (single-user local dev mode).
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated

# CORS
CORS_ORIGINS=http://localhost:3000
